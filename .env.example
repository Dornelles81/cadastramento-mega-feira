# Database Configuration (NEON PostgreSQL)
DATABASE_URL="postgresql://user:password@hostname:5432/dbname?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@hostname:5432/dbname?sslmode=require"

# Security (OBRIGATÓRIAS — a aplicação falha sem elas)
# MASTER_KEY: mínimo 32 caracteres; criptografa a biometria facial (AES-256-GCM).
# ATENÇÃO: trocar a MASTER_KEY torna ilegíveis os dados já criptografados.
MASTER_KEY="your-32-character-encryption-key-here"
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="https://your-domain.vercel.app"

# Cron de expurgo LGPD (Vercel Cron envia este token no header Authorization)
CRON_SECRET="your-cron-secret"
# Dias de retenção de dados biométricos após o fim do evento
DATA_RETENTION_DAYS="90"

# Application
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_NAME="Mega Feira Facial Recognition"

# E-mail transacional (Resend) — link de acesso dos responsáveis de stand
# Sem RESEND_FROM_EMAIL, usa o sandbox onboarding@resend.dev (só funciona em dev).
# Em produção, verificar o domínio megacredenciamento.com.br no painel do Resend
# (registros DKIM/SPF/Return-Path) e usar ex.: "Mega Credenciamento <credenciamento@megacredenciamento.com.br>"
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Optional - Development
NODE_ENV="development"

# HikCentral Configuration
HIKCENTAL_URL="https://127.0.0.1"
HIKCENTAL_USERNAME="admin"
HIKCENTAL_PASSWORD="your-hikcental-password"
HIKCENTAL_API_VERSION="/api/acs/v1"
HIKCENTAL_AUTH_TYPE="basic" # Options: basic, digest, apikey
HIKCENTAL_API_KEY="" # For API key auth
HIKCENTAL_API_SECRET="" # For API key auth

# HikCentral Library Settings
HIKCENTAL_LIBRARY_ID="1"
HIKCENTAL_LIBRARY_TYPE="blackFD"
HIKCENTAL_DEFAULT_ACCESS_LEVEL="1"
HIKCENTAL_VALIDITY_DAYS="90"

# HikCentral Rate Limiting
HIKCENTAL_BATCH_SIZE="100"
HIKCENTAL_MAX_RETRIES="3"
HIKCENTAL_RETRY_DELAY="5000"
HIKCENTAL_REQUEST_TIMEOUT="30000"
HIKCENTAL_RATE_LIMIT="10"

# HikCentral Auto Sync
HIKCENTAL_AUTO_SYNC="false"
HIKCENTAL_SYNC_INTERVAL="300"

# Hikvision Terminal Configuration (DS-K1T671M-L)
HIKVISION_DEVICE_IP="192.168.1.20"
HIKVISION_USER="admin"
HIKVISION_PASSWORD="your-device-password"

# HikCentral Web (login da interface web, usado como fallback de sync)
HIKCENTRAL_WEB_USER=""
HIKCENTRAL_WEB_PASSWORD=""

# WhatsApp Evolution API Configuration
# Set EVOLUTION_ENABLED=false to disable WhatsApp notifications
EVOLUTION_ENABLED="true"
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="your-evolution-api-key"
EVOLUTION_INSTANCE="megafeira"
